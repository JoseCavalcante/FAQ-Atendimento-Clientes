# ══════════════════════════════════════
# Atendimento & Suporte IA — SaaS Config
# ══════════════════════════════════════

# ── App ──
APP_NAME=Atendimento & Suporte IA
DEBUG=false

# ── Database ──
# SQLite (desenvolvimento):
DATABASE_URL=sqlite+aiosqlite:///saas.db
# PostgreSQL (produção):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/saas_db

# ── Auth / JWT ──
# IMPORTANTE: Gere uma chave segura para produção!
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM ──
GROQ_API_KEY=gsk_sua_chave_groq_aqui
OPENAI_API_KEY=sk-sua_chave_openai_aqui
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile
DEFAULT_TEMPERATURE=0.7

# ── Storage ──
STORAGE_BACKEND=local
# Para S3 (produção):
# STORAGE_BACKEND=s3
# S3_BUCKET=meu-bucket
# S3_REGION=us-east-1

# ── Embedding ──
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── CORS ──
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ── Billing (Stripe) ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── API Key (rotas legadas) ──
# Deixe vazio para desabilitar autenticação legacy
API_KEY=
